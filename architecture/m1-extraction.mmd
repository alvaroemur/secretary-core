flowchart TB

%% Modulo 1 - Extraccion (flowchart nivel 2)
%% Leyenda:
%%   [paso]            proceso
%%   {X condicion?}    gateway exclusivo - una rama
%%   {+ paralelo}      gateway paralelo - fork/join todas las ramas
%%   {O opcion}        gateway inclusivo - una o mas ramas
%%   ([trigger])       inicio/fin
%%   [(store)]         data store persistente interno
%%   [(store)] dashed  data store persistente externo (Gmail, GitHub, etc.)
%%   [/evento/]        evento o mensaje transitorio (one-shot)
%%   -->               flujo de control (orden de ejecucion)
%%   -.->              flujo de datos (lectura o escritura)

    %% --- 1.1 revision-correo ---
    subgraph S1[" 1.1 revision-correo "]
        direction TB
        T1([trigger: cron / manual])
        F1[fetch threads]
        C1[clasificar thread<br/>LLM]
        D1{"X tipo?"}
        A1[extraer accion]
        E1[guardar extracto]
        L1[aplicar label]
        END1([fin])

        IN1[(Gmail<br/>threads por label)]
        OUT1a[(acciones.md)]
        OUT1b[(memory/correo)]
        OUT1c[(Gmail<br/>labels)]

        %% control
        T1 --> F1 --> C1 --> D1
        D1 -- accionable --> A1 --> L1
        D1 -- informativo --> E1 --> L1
        D1 -- desahogo / ruido --> L1
        L1 --> END1

        %% datos
        IN1 -. lee .-> F1
        A1 -. escribe .-> OUT1a
        E1 -. escribe .-> OUT1b
        L1 -. aplica .-> OUT1c
    end

    %% --- 1.2 whatsapp-update ---
    subgraph S2[" 1.2 whatsapp-update "]
        direction TB
        T2([trigger: cron / manual])
        F2[leer chats]
        C2[clasificar mensaje<br/>LLM]
        D2{"X tipo?"}
        A2[extraer accion]
        E2[guardar extracto]
        SG2[marcar señal contextual<br/>NO accion]
        END2([fin])

        IN2[(WhatsApp<br/>chats recientes)]
        OUT2a[(acciones.md)]
        OUT2b[(memory/whatsapp)]

        %% control
        T2 --> F2 --> C2 --> D2
        D2 -- accionable --> A2 --> END2
        D2 -- informativo --> E2 --> END2
        D2 -- desahogo 1-on-1 --> SG2 --> END2

        %% datos
        IN2 -. lee .-> F2
        A2 -. escribe .-> OUT2a
        E2 -. escribe .-> OUT2b
        SG2 -. escribe .-> OUT2b
    end

    %% --- 1.3 reuniones-update ---
    subgraph S3[" 1.3 reuniones-update "]
        direction TB
        T3([trigger: cron / manual])
        F3[leer transcripts]
        M3[match transcript<br/>con evento]
        R3[resumir reunion<br/>LLM]
        D3{"X hay acciones?"}
        A3[extraer acciones]
        E3[guardar resumen]
        END3([fin])

        IN3a[(Tactiq<br/>transcripts)]
        IN3b[(Google Calendar<br/>eventos)]
        OUT3a[(acciones.md)]
        OUT3b[(memory/reuniones)]

        %% control
        T3 --> F3 --> M3 --> R3 --> D3
        D3 -- sí --> A3 --> E3
        D3 -- no --> E3
        E3 --> END3

        %% datos
        IN3a -. lee .-> F3
        IN3b -. lee .-> M3
        A3 -. escribe .-> OUT3a
        E3 -. escribe .-> OUT3b
    end

    %% --- estilos ---
    classDef inicio    fill:#c8e6c9,stroke:#2e7d32,color:#000;
    classDef fin       fill:#ffcdd2,stroke:#c62828,color:#000;
    classDef actividad fill:#bbdefb,stroke:#1565c0,color:#000;
    classDef gateway   fill:#fff9c4,stroke:#f9a825,color:#000;
    classDef io        fill:#e0e0e0,stroke:#616161,color:#000;
    classDef ioExt     fill:#f5f5f5,stroke:#616161,stroke-dasharray:5 5,color:#000;

    class T1,T2,T3 inicio;
    class END1,END2,END3 fin;
    class F1,C1,A1,E1,L1,F2,C2,A2,E2,SG2,F3,M3,R3,A3,E3 actividad;
    class D1,D2,D3 gateway;
    class OUT1a,OUT1b,OUT2a,OUT2b,OUT3a,OUT3b io;
    class IN1,IN2,IN3a,IN3b,OUT1c ioExt;
