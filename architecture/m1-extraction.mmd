flowchart TB

%% Module 1 - Extraction (level 2 flowchart)
%% Legend:
%%   [step]            process
%%   {X condition?}    exclusive gateway - one branch
%%   {+ parallel}      parallel gateway - fork/join all branches
%%   {O option}        inclusive gateway - one or more branches
%%   ([trigger])       start/end
%%   [(store)]         persistent internal data store
%%   [(store)] dashed  persistent external data store (Gmail, GitHub, etc.)
%%   [/event/]         transient event or message (one-shot)
%%   -->               control flow (execution order)
%%   -.->              data flow (read or write)

    %% --- 1.1 mail-review ---
    subgraph S1[" 1.1 mail-review "]
        direction TB
        T1([trigger: cron / manual])
        F1[fetch threads]
        C1[classify thread<br/>LLM]
        D1{"X type?"}
        A1[extract action]
        E1[save extract]
        L1[apply label]
        END1([end])

        IN1[(Gmail<br/>threads by label)]
        OUT1a[(acciones.md)]
        OUT1b[(memory/mail)]
        OUT1c[(Gmail<br/>labels)]

        %% control
        T1 --> F1 --> C1 --> D1
        D1 -- actionable --> A1 --> L1
        D1 -- informational --> E1 --> L1
        D1 -- venting / noise --> L1
        L1 --> END1

        %% data
        IN1 -. read .-> F1
        A1 -. write .-> OUT1a
        E1 -. write .-> OUT1b
        L1 -. apply .-> OUT1c
    end

    %% --- 1.2 whatsapp-update ---
    subgraph S2[" 1.2 whatsapp-update "]
        direction TB
        T2([trigger: cron / manual])
        F2[read chats]
        C2[classify message<br/>LLM]
        D2{"X type?"}
        A2[extract action]
        E2[save extract]
        SG2[mark contextual signal<br/>not action]
        END2([end])

        IN2[(WhatsApp<br/>recent chats)]
        OUT2a[(acciones.md)]
        OUT2b[(memory/whatsapp)]

        %% control
        T2 --> F2 --> C2 --> D2
        D2 -- actionable --> A2 --> END2
        D2 -- informational --> E2 --> END2
        D2 -- "venting (1-on-1)" --> SG2 --> END2

        %% data
        IN2 -. read .-> F2
        A2 -. write .-> OUT2a
        E2 -. write .-> OUT2b
        SG2 -. write .-> OUT2b
    end

    %% --- 1.3 meetings-update ---
    subgraph S3[" 1.3 meetings-update "]
        direction TB
        T3([trigger: cron / manual])
        F3[read transcripts]
        M3[match transcript<br/>to event]
        R3[summarize meeting<br/>LLM]
        D3{"X actions found?"}
        A3[extract actions]
        E3[save summary]
        END3([end])

        IN3a[(Tactiq<br/>transcripts)]
        IN3b[(Google Calendar<br/>events)]
        OUT3a[(acciones.md)]
        OUT3b[(memory/meetings)]

        %% control
        T3 --> F3 --> M3 --> R3 --> D3
        D3 -- yes --> A3 --> E3
        D3 -- no --> E3
        E3 --> END3

        %% data
        IN3a -. read .-> F3
        IN3b -. read .-> M3
        A3 -. write .-> OUT3a
        E3 -. write .-> OUT3b
    end

    %% --- styles ---
    classDef inicio    fill:#c8e6c9,stroke:#2e7d32,color:#000;
    classDef fin       fill:#ffcdd2,stroke:#c62828,color:#000;
    classDef actividad fill:#bbdefb,stroke:#1565c0,color:#000;
    classDef gateway   fill:#fff9c4,stroke:#f9a825,color:#000;
    classDef io        fill:#e0e0e0,stroke:#616161,color:#000;
    classDef ioExt     fill:#f5f5f5,stroke:#616161,stroke-dasharray:5 5,color:#000;

    class T1,T2,T3 inicio;
    class END1,END2,END3 fin;
    class F1,C1,A1,E1,L1,F2,C2,A2,E2,SG2,F3,M3,R3,A3,E3 actividad;
    class D1,D2,D3 gateway;
    class OUT1a,OUT1b,OUT2a,OUT2b,OUT3a,OUT3b io;
    class IN1,IN2,IN3a,IN3b,OUT1c ioExt;
