flowchart TB

%% Modulo 2 - Transformacion / Carga / Presentacion (flowchart nivel 2)
%% Leyenda:
%%   [paso]            proceso
%%   {X condicion?}    gateway exclusivo - una rama
%%   {+ paralelo}      gateway paralelo - fork/join todas las ramas
%%   {O opcion}        gateway inclusivo - una o mas ramas
%%   ([trigger])       inicio/fin
%%   [(store)]         data store persistente interno
%%   [(store)] dashed  data store persistente externo (Gmail, GitHub, etc.)
%%   [/evento/]        evento o mensaje transitorio (one-shot)
%%   -->               flujo de control (orden de ejecucion)
%%   -.->              flujo de datos (lectura o escritura)

    %% --- 2.1 wiki-update ---
    subgraph S1[" 2.1 wiki-update "]
        direction TB
        T1([trigger: cron / post-extraccion])
        SC1[escanear desde<br/>ultima corrida]
        D1{"X hay evidencias<br/>nuevas?"}
        DEC1[decidir articulos<br/>a tocar]
        ME1[merge via<br/>skill wiki-write]
        END1([fin])

        IN1[(memory/<br/>evidencias)]
        OUT1[(wiki/articulos<br/>markdown)]

        %% control
        T1 --> SC1 --> D1
        D1 -- no --> END1
        D1 -- sí --> DEC1 --> ME1 --> END1

        %% datos
        IN1 -. lee .-> SC1
        ME1 -. escribe .-> OUT1
    end

    %% --- 2.2 wiki-build ---
    subgraph S2[" 2.2 wiki-build "]
        direction TB
        T2([trigger: post wiki-update / manual])
        FORK2{"+ render<br/>en paralelo"}
        R2a[render articulos<br/>md a html]
        R2b[render home<br/>dashboard]
        R2c[render acciones.html]
        R2d[render notas.html]
        R2e[render estado.html]
        JOIN2{"+ esperar<br/>renders"}
        D2{"X cambios<br/>en output?"}
        CP2[commit + push<br/>auto-deploy]
        END2([fin])

        IN2a[(wiki/articulos)]
        IN2b[(acciones.md)]
        IN2c[(notas /<br/>handovers)]
        IN2d[(memory/<br/>logs rutinas)]
        OUT2a[(wiki/output<br/>panel HTML)]
        OUT2b[(Repo remoto<br/>alvaroemur/wiki<br/>Pages opcional)]

        %% control
        T2 --> FORK2
        FORK2 --> R2a --> JOIN2
        FORK2 --> R2b --> JOIN2
        FORK2 --> R2c --> JOIN2
        FORK2 --> R2d --> JOIN2
        FORK2 --> R2e --> JOIN2
        JOIN2 --> D2
        D2 -- sí --> CP2 --> END2
        D2 -- no --> END2

        %% datos: entrada
        IN2a -. lee .-> R2a
        IN2a -. resumenes .-> R2b
        IN2b -. top N .-> R2b
        IN2c -. recientes .-> R2b
        IN2b -. lee .-> R2c
        IN2c -. lee .-> R2d
        IN2d -. lee .-> R2e

        %% datos: salida
        R2a -. escribe .-> OUT2a
        R2b -. escribe .-> OUT2a
        R2c -. escribe .-> OUT2a
        R2d -. escribe .-> OUT2a
        R2e -. escribe .-> OUT2a
        CP2 -. push .-> OUT2b
    end

    %% --- estilos ---
    classDef inicio    fill:#c8e6c9,stroke:#2e7d32,color:#000;
    classDef fin       fill:#ffcdd2,stroke:#c62828,color:#000;
    classDef actividad fill:#bbdefb,stroke:#1565c0,color:#000;
    classDef gateway   fill:#fff9c4,stroke:#f9a825,color:#000;
    classDef io        fill:#e0e0e0,stroke:#616161,color:#000;
    classDef ioExt     fill:#f5f5f5,stroke:#616161,stroke-dasharray:5 5,color:#000;

    class T1,T2 inicio;
    class END1,END2 fin;
    class SC1,DEC1,ME1,R2a,R2b,R2c,R2d,R2e,CP2 actividad;
    class D1,D2,FORK2,JOIN2 gateway;
    class IN1,OUT1,IN2a,IN2b,IN2c,IN2d,OUT2a io;
    class OUT2b ioExt;
