flowchart TB

%% Module 2 - Transformation / Load / Presentation (level 2 flowchart)
%% Legend:
%%   [step]            process
%%   {X condition?}    exclusive gateway - one branch
%%   {+ parallel}      parallel gateway - fork/join all branches
%%   {O option}        inclusive gateway - one or more branches
%%   ([trigger])       start/end
%%   [(store)]         persistent internal data store
%%   [(store)] dashed  persistent external data store (Gmail, GitHub, etc.)
%%   [/event/]         transient event or message (one-shot)
%%   -->               control flow (execution order)
%%   -.->              data flow (read or write)

    %% --- 2.1 wiki-update ---
    subgraph S1[" 2.1 wiki-update "]
        direction TB
        T1([trigger: cron / post-extraction])
        SC1[scan since<br/>last run]
        D1{"X new evidence<br/>found?"}
        DEC1[decide articles<br/>to update]
        ME1[merge via<br/>skill wiki-write]
        END1([end])

        IN1[(memory/<br/>evidence)]
        OUT1[(wiki/articulos<br/>markdown)]

        %% control
        T1 --> SC1 --> D1
        D1 -- no --> END1
        D1 -- yes --> DEC1 --> ME1 --> END1

        %% data
        IN1 -. read .-> SC1
        ME1 -. write .-> OUT1
    end

    %% --- 2.2 wiki-build ---
    subgraph S2[" 2.2 wiki-build "]
        direction TB
        T2([trigger: post wiki-update / manual])
        FORK2{"+ render<br/>in parallel"}
        R2a[render articles<br/>md to html]
        R2b[render home<br/>dashboard]
        R2c[render actions.html]
        R2d[render notes.html]
        R2e[render status.html]
        JOIN2{"+ wait for<br/>renders"}
        D2{"X changes<br/>in output?"}
        CP2[commit + push<br/>auto-deploy]
        END2([end])

        IN2a[(wiki/articulos)]
        IN2b[(acciones.md)]
        IN2c[(notes /<br/>handovers)]
        IN2d[(memory/<br/>routine logs)]
        OUT2a[(wiki/output<br/>HTML panel)]
        OUT2b[(Remote repo<br/>Pages optional)]

        %% control
        T2 --> FORK2
        FORK2 --> R2a --> JOIN2
        FORK2 --> R2b --> JOIN2
        FORK2 --> R2c --> JOIN2
        FORK2 --> R2d --> JOIN2
        FORK2 --> R2e --> JOIN2
        JOIN2 --> D2
        D2 -- yes --> CP2 --> END2
        D2 -- no --> END2

        %% data: input
        IN2a -. read .-> R2a
        IN2a -. summaries .-> R2b
        IN2b -. top N .-> R2b
        IN2c -. recent .-> R2b
        IN2b -. read .-> R2c
        IN2c -. read .-> R2d
        IN2d -. read .-> R2e

        %% data: output
        R2a -. write .-> OUT2a
        R2b -. write .-> OUT2a
        R2c -. write .-> OUT2a
        R2d -. write .-> OUT2a
        R2e -. write .-> OUT2a
        CP2 -. push .-> OUT2b
    end

    %% --- styles ---
    classDef inicio    fill:#c8e6c9,stroke:#2e7d32,color:#000;
    classDef fin       fill:#ffcdd2,stroke:#c62828,color:#000;
    classDef actividad fill:#bbdefb,stroke:#1565c0,color:#000;
    classDef gateway   fill:#fff9c4,stroke:#f9a825,color:#000;
    classDef io        fill:#e0e0e0,stroke:#616161,color:#000;
    classDef ioExt     fill:#f5f5f5,stroke:#616161,stroke-dasharray:5 5,color:#000;

    class T1,T2 inicio;
    class END1,END2 fin;
    class SC1,DEC1,ME1,R2a,R2b,R2c,R2d,R2e,CP2 actividad;
    class D1,D2,FORK2,JOIN2 gateway;
    class IN1,OUT1,IN2a,IN2b,IN2c,IN2d,OUT2a io;
    class OUT2b ioExt;
