flowchart TB

%% Module 3 - Dispatch / Handover (level 2 flowchart)
%% Three choreographed processes:
%%   S  - automatic dispatch (mode A or B)
%%   H1 - human review of the brief (issue)
%%   H2 - human review of the PR
%% Legend:
%%   [step]            process
%%   {X condition?}    exclusive gateway - one branch
%%   {+ parallel}      parallel gateway - fork/join all branches
%%   {O option}        inclusive gateway - one or more branches
%%   ([trigger])       start/end
%%   [(store)]         persistent internal data store
%%   [(store)] dashed  persistent external data store (Gmail, GitHub, etc.)
%%   [/event/]         transient event or message (one-shot)
%%   -->               control flow (execution order)
%%   -.->              data flow / message between processes

    %% ───────────────────────────────────────────────────
    %% S - Automatic dispatch
    %% ───────────────────────────────────────────────────
    subgraph S[" S - automatic dispatch "]
        direction TB
        T([trigger: cron / post-extraction])
        T_A([alternate trigger:<br/>label dispatch:execute<br/>on issue])
        F[filter actions<br/>with target=repo]
        D0{"X pending<br/>actions?"}
        C[load context]
        H[generate handover<br/>skill handover]
        REG_B[save local note<br/>in notes/]
        DM{"X mode?<br/>default = B"}

        IB[create issue<br/>gh issue create<br/>body = HANDOVER.md]

        EA[launch executor<br/>agent in repo]
        CA[commits on<br/>new branch<br/>references issue #N]
        PA[open PR<br/>Closes #N]

        END_S([end S])

        IN_acc[(acciones.md)]
        IN_wiki[(wiki/articulos)]
        IN_mem[(memory/<br/>evidence)]
        OUT_notas[(notes /<br/>handovers<br/>master index)]
        OUT_issue[(GitHub Issue<br/>target repo)]
        OUT_branch[(Remote branch<br/>target repo)]
        OUT_PR[(GitHub PR<br/>Closes issue)]

        T --> F --> D0
        D0 -- no --> END_S
        D0 -- yes --> C --> H --> REG_B --> DM
        DM -- B brief --> IB --> END_S
        DM -- A executable --> EA --> CA --> PA --> END_S

        %% alternate start: mode A can be triggered
        %% directly from the label, skipping F/C/H
        T_A --> EA

        IN_acc -. read .-> F
        IN_wiki -. read .-> C
        IN_mem -. read .-> C
        REG_B -. write .-> OUT_notas
        IB -. create .-> OUT_issue
        CA -. push .-> OUT_branch
        PA -. open .-> OUT_PR
    end

    %% ───────────────────────────────────────────────────
    %% H1 - Human review of the brief (issue)
    %% ───────────────────────────────────────────────────
    subgraph H1[" H1 - brief review "]
        direction TB
        T_H1([trigger: mobile notif<br/>issue created])
        Read[User reads issue<br/>in GitHub app]
        Comment[comment / refine<br/>context on the issue]
        D_promo{"X approve<br/>execution?"}
        Trigger_A[apply label<br/>dispatch:execute]
        ManualWork[work the repo<br/>manually]
        PushManual[commits +<br/>push branch]
        OpenPR[open manual PR<br/>Closes #N]
        END_H1([end H1])

        T_H1 --> Read --> Comment --> D_promo
        D_promo -- yes, automate --> Trigger_A --> END_H1
        D_promo -- no, I'll do it --> ManualWork --> PushManual --> OpenPR --> END_H1

        %% data H1
        OUT_issue -. read .-> Read
        Comment -. comment .-> OUT_issue
        Trigger_A -. apply label .-> OUT_issue
        PushManual -. push .-> OUT_branch
        OpenPR -. open .-> OUT_PR
    end

    %% ───────────────────────────────────────────────────
    %% H2 - Human review of the PR
    %% ───────────────────────────────────────────────────
    subgraph H2[" H2 - PR review "]
        direction TB
        T_H2([trigger: mobile notif<br/>PR opened])
        ReadPR[User reads PR<br/>in GitHub app]
        D_pr{"X PR is OK?"}
        Merge[merge to main]
        Request[request changes<br/>comment on PR]
        END_H2([end H2])

        OUT_main[(Main branch<br/>updated)]

        T_H2 --> ReadPR --> D_pr
        D_pr -- yes --> Merge --> END_H2
        D_pr -- no --> Request --> END_H2

        %% data H2
        OUT_PR -. read .-> ReadPR
        Merge -. merge .-> OUT_main
        Request -. comment .-> OUT_PR
    end

    %% ───────────────────────────────────────────────────
    %% Choreography between processes (messages / events)
    %% ───────────────────────────────────────────────────
    OUT_issue -. event .-> T_H1
    OUT_issue -. label event .-> T_A
    OUT_PR -. event .-> T_H2

    %% --- styles ---
    classDef inicio    fill:#c8e6c9,stroke:#2e7d32,color:#000;
    classDef fin       fill:#ffcdd2,stroke:#c62828,color:#000;
    classDef actividad fill:#bbdefb,stroke:#1565c0,color:#000;
    classDef gateway   fill:#fff9c4,stroke:#f9a825,color:#000;
    classDef io        fill:#e0e0e0,stroke:#616161,color:#000;
    classDef ioExt     fill:#f5f5f5,stroke:#616161,stroke-dasharray:5 5,color:#000;

    class T,T_A,T_H1,T_H2 inicio;
    class END_S,END_H1,END_H2 fin;
    class F,C,H,REG_B,IB,EA,CA,PA,Read,Comment,Trigger_A,ManualWork,PushManual,OpenPR,ReadPR,Merge,Request actividad;
    class D0,DM,D_promo,D_pr gateway;
    class IN_acc,IN_wiki,IN_mem,OUT_notas io;
    class OUT_issue,OUT_branch,OUT_PR,OUT_main ioExt;
