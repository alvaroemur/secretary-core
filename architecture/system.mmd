flowchart LR

%% Secretary — Level 1 architecture (DFD)
%% Convention:
%%   [X]    external entity
%%   ([X])  process (numbered)
%%   [(X)]  data store
%%
%% Editable source of truth. Reflect any structural change
%% here before (or alongside) implementing it in code.

    %% --- External entities ---
    Gmail[Gmail]
    WA[WhatsApp]
    Tactiq[Tactiq / Meetings]
    Cal[Google Calendar]
    User[User]
    Repos[External repos]

    %% --- Module 1: Extraction ---
    subgraph M1[" 1. Extraction "]
        direction TB
        P1([1.1 mail-review])
        P2([1.2 whatsapp-update])
        P3([1.3 meetings-update])
        DS_mem[("memory/<br/>evidence")]
        DS_acc[("acciones.md")]
        P1 --> DS_mem
        P2 --> DS_mem
        P3 --> DS_mem
        P1 --> DS_acc
        P2 --> DS_acc
        P3 --> DS_acc
    end

    %% --- Module 2: Transformation / Load / Presentation ---
    subgraph M2[" 2. Transformation / Load / Presentation "]
        direction TB
        P4([2.1 wiki-update])
        P5([2.2 wiki-build])
        DS_wiki[("wiki/articulos")]
        DS_html[("wiki/output<br/>HTML panel<br/>home + actions<br/>+ notes + wiki<br/>+ status")]
        P4 --> DS_wiki
        DS_wiki --> P5 --> DS_html
    end

    %% --- Module 3: Dispatch / Handover ---
    subgraph M3[" 3. Dispatch / Handover "]
        direction TB
        P6([3.1 dispatch])
        DS_notas[("notes /<br/>handovers")]
        P6 --> DS_notas
    end

    %% --- Flows between modules ---
    Gmail --> P1
    WA --> P2
    Tactiq --> P3
    Cal --> P3

    DS_mem --> P4
    DS_acc --> P6
    DS_wiki -. context .-> P6

    %% wiki-build adds actions and notes to the HTML panel
    DS_acc --> P5
    DS_notas --> P5
    DS_mem -. status logs .-> P5

    P6 --> Repos
    DS_notas --> User
    DS_html --> User

    %% --- styles ---
    classDef actividad fill:#bbdefb,stroke:#1565c0,color:#000;
    classDef io        fill:#e0e0e0,stroke:#616161,color:#000;

    class P1,P2,P3,P4,P5,P6 actividad;
    class Gmail,WA,Tactiq,Cal,User,Repos,DS_mem,DS_acc,DS_wiki,DS_html,DS_notas io;
