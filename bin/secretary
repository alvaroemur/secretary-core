#!/usr/bin/env bash
# Run secretary CLI without pip install (dev fallback).
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
export SECRETARY_CORE="${SECRETARY_CORE:-$ROOT}"
export SECRETARY_INSTANCE="${SECRETARY_INSTANCE:-$HOME/.secretary}"
export PYTHONPATH="${ROOT}${PYTHONPATH:+:$PYTHONPATH}"
exec python3 -m secretary.main "$@"
